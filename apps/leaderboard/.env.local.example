# Leaderboard Environment Configuration
# Copy this to .env.local and adjust as needed

# ==========================================
# Envio GraphQL Endpoints
# ==========================================
# For local development with the simulation environment:
VITE_ENVIO_MAINNET_ENDPOINT=http://localhost:8080/v1/graphql
VITE_ENVIO_TESTNET_ENDPOINT=http://localhost:8080/v1/graphql

# For production, set these to the deployed Envio endpoints:
# VITE_ENVIO_MAINNET_ENDPOINT=https://indexer.tangle.tools/v1/graphql
# VITE_ENVIO_TESTNET_ENDPOINT=https://testnet-indexer.tangle.tools/v1/graphql

# ==========================================
# Local Simulation Environment (optional)
# ==========================================
# These are used by the activity generator script
RPC_URL=http://localhost:8545
ACTIVITY_INTERVAL_MS=10000
