# Migration Claim Configuration
# Copy this file to .env.local and update values after running deploy-local-complete.sh

# TangleMigration contract address (required for claim functionality)
# Get this from the deploy script output
VITE_TANGLE_MIGRATION_ADDRESS=

# Claim relayer URL (optional - enables gasless claiming)
# Start the relayer with: cd apps/claim-relayer && yarn dev
VITE_CLAIM_RELAYER_URL=http://localhost:3001

# Migration merkle data URL (default is correct for local setup)
# Local scripts copy tnt-core/packages/migration-claim/merkle-tree.json to this path.
VITE_MIGRATION_PROOFS_URL=/data/migration-proofs.json

# SP1 Prover API URL (optional - leave empty for mock proof in local dev)
# For production, set to your SP1 prover endpoint
VITE_SP1_PROVER_API_URL=

# Force mock proof generation (useful for local testing)
# When true or when VITE_SP1_PROVER_API_URL is empty in dev, uses mock proofs
VITE_MOCK_PROOF=true
