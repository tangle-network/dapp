# Base mainnet infra configuration
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org

HASURA_EXTERNAL_PORT=8082
CLAIM_RELAYER_PORT=3002
PROVER_API_PORT=8082
ENVIO_INDEXER_PORT=9899
ENVIO_PG_PORT=5434

# Optional override if manifest is not at tnt-core/deployments/base/latest.json
# MANIFEST_PATH=/path/to/deployments/base/latest.json

# dApp overrides
VITE_MIGRATION_RPC_URL=https://mainnet.base.org
VITE_MIGRATION_PROOFS_URL=/data/migration-proofs.json
VITE_MOCK_PROOF=false
VITE_CREDITS_TREE_URL_8453=/data/credits-tree.json

# SP1 prover defaults
SP1_PROVER=network
VERIFY_ONCHAIN=true
VERIFY_PROOF=false
ALLOW_MOCK=false
# Optional overrides (auto-filled from tnt-core manifest when empty)
SP1_PROGRAM_VKEY=
SP1_VERIFIER_ADDRESS=

# Required at runtime (export before running):
# RELAYER_PRIVATE_KEY=0x...
# NETWORK_PRIVATE_KEY=0x...
