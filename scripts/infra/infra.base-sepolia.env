# Base Sepolia infra configuration
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

HASURA_EXTERNAL_PORT=8080
CLAIM_RELAYER_PORT=3001
PROVER_API_PORT=8081
ENVIO_INDEXER_PORT=9898
ENVIO_PG_PORT=5433

# Optional override if manifest is not at tnt-core/deployments/base-sepolia/latest.json
# MANIFEST_PATH=/path/to/deployments/base-sepolia/latest.json

# dApp overrides
VITE_MIGRATION_RPC_URL=https://sepolia.base.org
VITE_MIGRATION_PROOFS_URL=/data/migration-proofs.json
VITE_MOCK_PROOF=false
VITE_CREDITS_TREE_URL_84532=/data/credits-tree.json

# SP1 prover defaults
SP1_PROVER=network
VERIFY_ONCHAIN=true
VERIFY_PROOF=false
ALLOW_MOCK=false
# Optional overrides (auto-filled from tnt-core manifest when empty)
SP1_PROGRAM_VKEY=
SP1_VERIFIER_ADDRESS=

# Required at runtime (export before running):
# RELAYER_PRIVATE_KEY=0x...
# NETWORK_PRIVATE_KEY=0x...
